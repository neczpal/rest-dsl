api NewTypesApi {
    meta {
        title: "New Types API"
        version: "1.0.0"
        base: "/api"
    }

    models {
        NewTypes {
            dateTime: DateTime
            date: Date
            time: Time
            float: Float
            long: Long
            binary: Binary
        }
    }

    paths {
        /new-types {
            get getNewTypes -> NewTypes
        }
    }
}
