api Petstore {
    title: "Petstore API"
    version: "1.0.0"
    base: "/api/v3"
}

model User {
    id: Int
    username: String
    email: String
}

service UserService {
    base: "/user"

    get getUser {
        path: "/{username}"
        responses: {
            200: User
            404: "User not found"
        }
    }

    post createUser {
        body: User
        responses: {
            201: User
        }
    }
}
